{
  "version": 2,
  "buildCommand": "pnpm --filter @v2/web run build",
  "outputDirectory": "v2/apps/web/dist",
  "builds": [
    {
      "src": "v2/api/*.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "v2/api/$1.ts" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
