{
  "version": 2,
  "builds": [
    {
      "src": "artifacts/serrurier-express/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "artifacts/api-server/api/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "artifacts/api-server/api/index.ts" },
    { "src": "^/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
